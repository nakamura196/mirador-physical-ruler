{
  "name": "mirador-physical-ruler",
  "version": "1.0.0",
  "description": "A Mirador 4 plugin that displays a physical dimensions ruler using IIIF physdim service",
  "main": "./dist/mirador-physical-ruler.js",
  "module": "./src/index.jsx",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./src": "./src/index.jsx",
    ".": {
      "import": "./dist/mirador-physical-ruler.es.js",
      "require": "./dist/mirador-physical-ruler.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "start": "vite",
    "build:demo": "vite build --config vite.demo.config.js"
  },
  "peerDependencies": {
    "mirador": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "mirador": "^4.0.0",
    "playwright": "^1.58.2",
    "react": "^18.0.0",
    "react-dom": "^19.2.5",
    "vite": "^6.0.0"
  },
  "keywords": [
    "mirador",
    "iiif",
    "plugin",
    "ruler",
    "physical-dimensions"
  ],
  "license": "MIT"
}
